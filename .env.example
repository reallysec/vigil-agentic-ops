# ---- LLM backend (OpenAI-compatible: Volcengine Ark by default) ----
# Volcengine Ark (火山方舟) console: https://console.volcengine.com/ark
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your-volcengine-ark-api-key
# Use a model/endpoint id that supports tool/function calling, e.g. doubao-seed-1-6
LLM_MODEL=doubao-seed-1-6-250615
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000

# ---- Splunk (already provisioned in the ttwin-splunk container) ----
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=Admin@123
# A Splunk JWT is read from .splunk_token automatically; set SPLUNK_TOKEN to override.
SPLUNK_CONTAINER=17c09f1147ce
HEC_TOKEN=8a4ac72d-7db4-42ef-b9f8-475648725a0c
